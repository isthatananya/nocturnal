APP_ENV=development
SECRET_KEY=replace-me-with-32-bytes-from-openssl-rand-hex-32
ALLOWED_ORIGINS=["http://localhost:5173"]
REDIS_URL=redis://localhost:6379/0
SESSION_TTL=604800

# Bureau integration — 'mock' uses the bundled synthetic 40-profile dataset
# (default for dev). Switch to 'cibil' + supply the next two values to activate
# a real bureau client (requires implementing CibilClient.lookup in
# backend/credit/bureau.py).
BUREAU_PROVIDER=mock
# CIBIL_API_BASE_URL=
# CIBIL_API_KEY=

VITE_API_URL=http://localhost:8000
VITE_NETWORK_ID=preprod
VITE_INDEXER_URL=https://indexer.preprod.midnight.network/api/v4/graphql
VITE_INDEXER_WS=wss://indexer.preprod.midnight.network/api/v4/graphql/ws
VITE_NODE_RPC=https://rpc.preprod.midnight.network
VITE_PROOF_SERVER_URL=http://localhost:6300

# Set after deploying credit_lending.compact via the in-app /deploy page.
# Empty = the UI shows an instructive "deploy first" screen (Option B).
VITE_CONTRACT_ADDRESS=

# Set to "1" only on demo machines where a wallet cannot be installed;
# enables the wallet-bypass demo path in LoanApply.tsx + LoanActive.tsx.
# VITE_DEMO_MODE=
