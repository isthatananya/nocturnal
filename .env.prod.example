# ── Backend ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-64-char-hex

APP_ENV=production
SESSION_TTL=604800
REDIS_URL=redis://redis:6379/0

# Set to your public domain, e.g. https://nocturned.example.com
ALLOWED_ORIGINS=["https://YOUR_DOMAIN"]

BUREAU_PROVIDER=mock

# ── Midnight / Vite (baked into JS bundle at build time) ─────────────────────
# Leave VITE_API_URL empty when nginx proxies /api/ → backend on the same host
VITE_API_URL=

VITE_NETWORK_ID=preprod
VITE_INDEXER_URL=https://indexer.preprod.midnight.network/api/v4/graphql
VITE_INDEXER_WS=wss://indexer.preprod.midnight.network/api/v4/graphql/ws
VITE_NODE_RPC=https://rpc.preprod.midnight.network

# nginx proxies /proof/ → proof-server container, so this stays as /proof
VITE_PROOF_SERVER_URL=/proof

# Paste here after deploying via /deploy page (empty = Option B / demo mode)
VITE_CONTRACT_ADDRESS=

# Set to "1" on machines where Lace can't be installed (bypasses wallet check)
# VITE_DEMO_MODE=1
